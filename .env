# EPG App - Environment Configuration
# Copy this file to .env and edit before running docker compose up

# --- Database ---
# Password for the internal PostgreSQL database
POSTGRES_PASSWORD=mypasshere

# --- Application ---
# A long random secret key for Flask sessions — CHANGE THIS
SECRET_KEY=your_random_key_here

# Port the app will be available on your host machine
APP_PORT=5000

# --- Security: IP Whitelist ---
# Comma-separated IPs that are never auto-banned (add your LAN IP here)
# Example: WHITELIST_IPS=127.0.0.1,192.168.1.10,192.168.1.50
WHITELIST_IPS=127.0.0.1
